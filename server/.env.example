# Copy this file to .env and fill in real values — NEVER commit .env
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET

PORT=3001
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# ─── Cloudflare R2 (image uploads) ───────────────────────────────────────────
# Account ID: Cloudflare Dashboard → R2 → Overview
R2_ACCOUNT_ID=your_account_id
# API token with R2:Edit permission (Cloudflare Dashboard → R2 → Manage R2 API Tokens)
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
# Name of the bucket created in R2
R2_BUCKET_NAME=menuqr-images
# Public URL for the bucket (enable "Public access" in the bucket settings first)
# Format: https://pub-xxxxxxxxxxxx.r2.dev  OR  https://cdn.yoursite.com
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# ─── Brevo (transactional email) ─────────────────────────────────────────────
# API key: Brevo Dashboard → SMTP & API → API Keys
BREVO_API_KEY=xkeysib-REPLACE_WITH_YOUR_BREVO_API_KEY
# Sender email address verified in Brevo (Settings → Senders & IPs → Senders)
BREVO_SENDER_EMAIL=noreply@yourdomain.com
